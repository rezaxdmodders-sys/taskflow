{
  "id": "com.rezanr.taskflowpro",
  "name": "TaskFlow Pro",
  "short_name": "TaskFlow",
  "description": "Enterprise Temporal Task Management Ecosystem with Low-Level Hardware Optimization.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["tabbed", "window-controls-overlay", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#0d1117",
  "theme_color": "#0d1117",
  "lang": "id",
  "dir": "ltr",
  "categories": ["productivity", "utilities"],
  "icons": [
    {
      "src": "https://cdn-icons-png.flaticon.com/512/9068/9068672.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "https://cdn-icons-png.flaticon.com/512/9068/9068672.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=1280",
      "sizes": "1280x720",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "TaskFlow Pro Desktop Hub"
    },
    {
      "src": "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=720",
      "sizes": "720x1280",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "TaskFlow Pro Mobile Focus"
    }
  ],
  "shortcuts": [
    {
      "name": "Tambah Tugas Baru",
      "short_name": "Tambah",
      "description": "Langsung buka input tugas mendesak",
      "url": "/?action=add",
      "icons": [{ "src": "https://cdn-icons-png.flaticon.com/512/9068/9068672.png", "sizes": "512x512" }]
    }
  ],
  "share_target": {
    "action": "/?share=true",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "file_handlers": [
    {
      "action": "/?file-open=true",
      "name": "TaskFlow Task File",
      "accept": {
        "text/plain": [".txt"],
        "application/json": [".task", ".json"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+taskflow",
      "url": "/?protocol=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 360
  }
}
